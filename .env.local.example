# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Allowlist de emails autorizados (separados por coma).
# Si se omite, por defecto: msanjuan@gnerai.com,mcortada@gnerai.com
ALLOWED_EMAILS=msanjuan@gnerai.com,mcortada@gnerai.com

# Telegram (opcional pero recomendado para notificaciones automáticas).
# Crea un bot con @BotFather y guarda aquí su token.
TELEGRAM_BOT_TOKEN=

# Cron — secreto para proteger /api/cron/*.
# En Vercel, define la variable CRON_SECRET en Project Settings y el scheduler
# añadirá automáticamente Authorization: Bearer <CRON_SECRET> a las llamadas.
# En desarrollo puedes dejarlo vacío y los endpoints aceptarán llamadas sin auth.
CRON_SECRET=
